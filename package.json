{
  "name": "@minhchi1509/facebook-profile-cleaner",
  "description": "Automate Facebook profile cleanup and statistics export (friends, followings, pages, groups, posts, reactions, comments).",
  "version": "1.2.1",
  "main": "./dist/main.cjs",
  "module": "./dist/main.mjs",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.mjs",
      "require": "./dist/main.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "rollup:build": "rollup -c rollup.config.ts --configPlugin typescript",
    "build": "rm -rf dist && npm run rollup:build && npm run bundle:dts",
    "build:dts": "rollup -c rollup.dts.mjs",
    "bundle:dts": "dts-bundle-generator -o dist/main.d.ts src/main.ts",
    "patch:publish": "npm version patch && npm publish --access public",
    "minor:publish": "npm version minor && npm publish --access public",
    "major:publish": "npm version major && npm publish --access public"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.5.0",
    "dts-bundle-generator": "^9.5.1",
    "rollup": "^4.60.1",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-typescript-paths": "^1.5.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@fast-csv/format": "^5.0.5",
    "@fast-csv/parse": "^5.0.5",
    "axios": "^1.14.0",
    "dayjs": "^1.11.20",
    "fast-csv": "^5.0.5",
    "tslib": "^2.8.1"
  },
  "keywords": [
    "facebook",
    "facebook-profile-cleaner",
    "automation",
    "cleanup",
    "privacy",
    "batch-processing",
    "mass-delete",
    "friends-management",
    "posts-management"
  ],
  "author": "minhchi1509",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/minhchi1509/facebook_profile_cleaner.git"
  },
  "bugs": {
    "url": "https://github.com/minhchi1509/facebook_profile_cleaner/issues"
  },
  "homepage": "https://github.com/minhchi1509/facebook_profile_cleaner"
}
